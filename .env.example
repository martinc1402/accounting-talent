# Supabase. Copy to .env.local and fill in.
#
# Until these are set, the application form and the employer waitlist still
# work end to end: the server actions validate, score, and log the payload to
# the terminal instead of inserting. That is deliberate, so the funnel is
# testable before the database exists.
#
# The service role key bypasses RLS and must never be exposed to the browser.
# Do not prefix it with NEXT_PUBLIC_.

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend, for the Stage 2 assessment emails (invite / pass / fail).
# In development, if this is unset the emails are logged as [EMAIL-MOCK] and the
# whole flow still works. In PRODUCTION a missing key makes the admin send routes
# fail loudly and refuse to change state, so nothing is marked verified/invited
# without an email actually going out. Requires a verified sending domain
# (mail.accountingtalent.in) in Resend.
RESEND_API_KEY=

# Secret for the internal admin routes (/api/admin/assessment/invite and
# /result). Server-only — never prefix with NEXT_PUBLIC_. Use a long random value
# (32+ bytes, e.g. `openssl rand -hex 32`) and set it only in Vercel env (and
# .env.local for local testing). The routes 404 without a matching bearer.
ADMIN_TASK_SECRET=

# Signing secret for the Resend bounce webhook (/api/webhooks/resend). Server-only
# — never NEXT_PUBLIC_. It's the `whsec_...` value shown when you create the
# webhook in the Resend dashboard (subscribe it to email.bounced and
# email.complained). The route rejects any request whose Svix signature doesn't
# verify against this, so a bounce can't be spoofed. See docs/admin-tasks.md.
RESEND_WEBHOOK_SECRET=

# Optional. The public origin used to build assessment links in emails. Defaults
# to the request host, or https://accountingtalent.in.
NEXT_PUBLIC_SITE_URL=

# Meta (Facebook) Pixel / dataset id. Public by design (NEXT_PUBLIC_, exposed to
# the browser). The pixel loads and fires ONLY in production (VERCEL_ENV ===
# "production") AND only when this is set — unset means nothing loads, nothing
# fires, and no id appears in the bundle. There is no hardcoded fallback id.
NEXT_PUBLIC_META_PIXEL_ID=
